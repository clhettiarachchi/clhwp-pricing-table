{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "clh/pricing-column",
  "version": "1.0.0",
  "title": "Pricing Column",
  "category": "layout",
  "parent": [ "clh/pricing-table" ],
  "description": "An individual pricing column card representing a single tier/plan.",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "price": {
      "type": "string",
      "default": ""
    },
    "description": {
      "type": "string",
      "default": ""
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "buttonText": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "clhwp-pricing",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
